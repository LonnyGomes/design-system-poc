          "default": "class CoButton extends LitElement { constructor() { super(...arguments); /** The button variant. */ this.variant = 'primary'; /** The button size. */ this.size = 'md'; /** Disables the button. */ this.disabled = false; /** Shows a loading spinner. */ this.loading = false; /** The button type (submit, reset, button). */ this.type = 'button'; } get _slVariant() { return variantMap[this.variant] ?? 'primary'; } get _slSize() { return sizeMap[this.size] ?? 'medium'; } _handleFocus() { this.dispatchEvent(new CustomEvent('co-focus', { bubbles: true, composed: true })); } _handleBlur() { this.dispatchEvent(new CustomEvent('co-blur', { bubbles: true, composed: true })); } render() { return html ` <sl-button variant=${this._slVariant} size=${this._slSize} ?disabled=${this.disabled} ?loading=${this.loading} type=${this.type} href=${ifDefined(this.href)} target=${ifDefined(this.target)} exportparts=\"base, label, prefix, suffix\" @sl-focus=${this._handleFocus} @sl-blur=${this._handleBlur} > <slot name=\"prefix\" slot=\"prefix\"></slot> <slot></slot> <slot name=\"suffix\" slot=\"suffix\"></slot> </sl-button> `; } }",
          "summary": "A button component wrapping Shoelace's sl-button with Cobalt theming."
        }
